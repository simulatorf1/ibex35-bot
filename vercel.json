{
  "version": 2,
  "builds": [
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/web/(.*\\.(js|css|png|jpg|svg|ico))",
      "dest": "/web/$1"
    },
    {
      "src": "/web/index.html",
      "dest": "/web/index.html"
    },
    {
      "src": "/web/dashboard.html",
      "dest": "/web/dashboard.html"
    },
    {
      "src": "/(.*)",
      "dest": "/web/index.html"
    }
  ]
}
